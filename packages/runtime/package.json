{
  "name": "@minpeter/pss-runtime",
  "version": "0.3.0-next.0",
  "description": "Generic agent runtime for threads, model loops, and synchronized run events.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@minpeter/pss-source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./platform/memory": {
      "@minpeter/pss-source": "./src/platform/memory/index.ts",
      "types": "./dist/platform/memory/index.d.ts",
      "import": "./dist/platform/memory/index.js"
    },
    "./platform/cloudflare": {
      "@minpeter/pss-source": "./src/platform/cloudflare/index.ts",
      "types": "./dist/platform/cloudflare/index.d.ts",
      "import": "./dist/platform/cloudflare/index.js"
    },
    "./platform/cloudflare/image-codecs": {
      "@minpeter/pss-source": "./src/platform/cloudflare/image-codecs-edge.ts",
      "types": "./dist/platform/cloudflare/image-codecs-edge.d.ts",
      "import": "./dist/platform/cloudflare/image-codecs-edge.js"
    },
    "./platform/file": {
      "@minpeter/pss-source": "./src/platform/file/index.ts",
      "types": "./dist/platform/file/index.d.ts",
      "import": "./dist/platform/file/index.js"
    },
    "./execution": {
      "@minpeter/pss-source": "./src/execution/index.ts",
      "types": "./dist/execution/index.d.ts",
      "import": "./dist/execution/index.js"
    },
    "./namespace": {
      "@minpeter/pss-source": "./src/namespace.ts",
      "types": "./dist/namespace.d.ts",
      "import": "./dist/namespace.js"
    },
    "./evals": {
      "@minpeter/pss-source": "./src/evals/index.ts",
      "types": "./dist/evals/index.d.ts",
      "import": "./dist/evals/index.js"
    }
  },
  "bin": {
    "pss-eval": "./dist/evals/cli-bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minpeter/pss-runtime.git",
    "directory": "packages/runtime"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:storage-stress": "vitest run src/platform/cloudflare/storage/execution/store-stress.test.ts src/platform/cloudflare/storage/execution/store-oversized-payload.test.ts",
    "test:storage-stress:extreme": "PSS_RUNTIME_STORAGE_STRESS_PROFILE=extreme vitest run src/platform/cloudflare/storage/execution/store-stress.test.ts",
    "test:storage-stress:heavy": "PSS_RUNTIME_STORAGE_STRESS_PROFILE=heavy vitest run src/platform/cloudflare/storage/execution/store-stress.test.ts src/platform/cloudflare/storage/execution/store-oversized-payload.test.ts",
    "test:storage-stress:torture": "PSS_RUNTIME_STORAGE_STRESS_PROFILE=torture vitest run src/platform/cloudflare/storage/execution/store-stress.test.ts src/platform/cloudflare/storage/execution/store-oversized-payload.test.ts",
    "lint": "ultracite check ."
  },
  "dependencies": {
    "@jsquash/avif": "^2.1.1",
    "@jsquash/webp": "^1.5.0",
    "ai": "7.0.16",
    "fast-png": "^8.0.0",
    "heic-decode": "^2.1.0",
    "jpeg-js": "^0.4.4",
    "libheif-js": "^1.19.8"
  },
  "devDependencies": {
    "agents": "0.17.4",
    "tsdown": "^0.22.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  }
}
