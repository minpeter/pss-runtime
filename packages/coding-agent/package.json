{
  "name": "@pss-next/coding-agent",
  "version": "0.0.0",
  "description": "Coding-agent product tools and TUI wiring for pss-next.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@pss-next/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tui": {
      "@pss-next/source": "./src/tui.ts",
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minpeter/pss-next.git",
    "directory": "packages/coding-agent"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node ../../scripts/fix-esm-imports.mjs dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "ultracite check ."
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.74.1",
    "@pss-next/runtime": "workspace:*",
    "ai": "7.0.0-canary.142",
    "zod": "^4.4.3"
  }
}
