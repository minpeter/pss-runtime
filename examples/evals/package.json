{
  "name": "@minpeter/pss-example-evals",
  "private": true,
  "type": "module",
  "scripts": {
    "evidence:assemble-cache-confirmation": "node src/assemble-cache-confirmation.mjs",
    "eval": "tsx --conditions=@minpeter/pss-source src/run.ts",
    "eval:cache-broad": "node src/broad-context-cache-benchmark.mjs",
    "test:cache-broad-helpers": "node --test src/broad-context-cache-response.test.mjs src/freerouter-url.test.mjs",
    "eval:cache-live": "tsx --conditions=@minpeter/pss-source src/live-cache-telemetry.ts",
    "eval:json": "tsx --conditions=@minpeter/pss-source src/run.ts --json",
    "evidence:verify-cache": "node src/verify-cache-evidence.mjs",
    "test": "node --test src/broad-context-cache-response.test.mjs src/cache-confirmation-evidence.test.mjs src/freerouter-url.test.mjs && node src/verify-cache-evidence.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "3.0.2",
    "@minpeter/pss-runtime": "workspace:*",
    "@t3-oss/env-core": "^0.13.11",
    "ai": "7.0.16",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.22.4",
    "typescript": "^7.0.2"
  }
}
