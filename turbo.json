{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["tsconfig.base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!README.md",
        "!CHANGELOG.md",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts",
        "!src/test-fixtures.ts",
        "!src/**/test-fixtures.ts"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "lint": {
      "cache": false
    }
  }
}
