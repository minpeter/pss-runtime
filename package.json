{
  "name": "pss-next",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx --conditions=@minpeter/pss-source examples/basic.ts",
    "dev:tui": "tsx --conditions=@minpeter/pss-source packages/coding-agent/src/tui.ts",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck && tsc -p tsconfig.json --noEmit",
    "test": "turbo run test && vitest run scripts/*.test.mjs",
    "lint": "ultracite check .",
    "format": "ultracite fix .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "release:next": "pnpm build && changeset publish",
    "verify:release": "node scripts/verify-release-artifacts.mjs",
    "boundaries": "turbo boundaries",
    "repo:packages": "turbo query ls --output json",
    "repo:affected": "turbo query affected"
  },
  "devDependencies": {
    "@ai-sdk/openai-compatible": "3.0.0-canary.48",
    "@biomejs/biome": "2.4.16",
    "@changesets/cli": "^2.31.0",
    "@minpeter/pss-coding-agent": "workspace:*",
    "@minpeter/pss-runtime": "workspace:*",
    "@t3-oss/env-core": "^0.13.11",
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.3",
    "turbo": "^2.9.15",
    "typescript": "^6.0.3",
    "ultracite": "7.8.0",
    "vitest": "^4.1.7",
    "zod": "^4.4.3"
  }
}
