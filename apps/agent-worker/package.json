{
  "name": "@minpeter/pss-agent-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @minpeter/pss-runtime build",
    "webhook:init": "tsx --conditions=@minpeter/pss-source scripts/webhook/init.ts",
    "webhook:remove": "tsx --conditions=@minpeter/pss-source scripts/webhook/remove.ts",
    "commands:register": "tsx --conditions=@minpeter/pss-source scripts/webhook/commands.ts",
    "predev": "run-s build webhook:remove commands:register",
    "dev:poll": "tsx --conditions=@minpeter/pss-source scripts/dev/poll.ts",
    "dev:worker": "wrangler dev",
    "dev": "run-p dev:*",
    "predeploy": "run-s build webhook:init",
    "deploy": "wrangler deploy",
    "pretest": "pnpm --filter @minpeter/pss-web-tools build",
    "test": "vitest run",
    "test:live:telegram-ux": "AGENT_TELEGRAM_LIVE=1 vitest run src/telegram/ux-tools.live.test.ts",
    "typecheck": "tsc -p tsconfig.worker.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "3.0.0-canary.48",
    "@chat-adapter/telegram": "4.30.0",
    "@minpeter/pss-runtime": "workspace:*",
    "@minpeter/pss-web-tools": "workspace:*",
    "ai": "7.0.0-canary.142",
    "chat": "4.30.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260608.1",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "wrangler": "^4.98.0"
  }
}
