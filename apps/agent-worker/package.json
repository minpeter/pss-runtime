{
  "name": "@minpeter/pss-agent-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @minpeter/pss-runtime build",
    "init:webhook": "tsx --conditions=@minpeter/pss-source scripts/telegram-webhook-init.ts",
    "predev": "pnpm run build",
    "dev": "tsx --conditions=@minpeter/pss-source scripts/dev-local.ts",
    "predeploy": "run-s build init:webhook",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.worker.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "3.0.0-canary.48",
    "@chat-adapter/telegram": "4.30.0",
    "@minpeter/pss-runtime": "workspace:*",
    "ai": "7.0.0-canary.142",
    "chat": "4.30.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260608.1",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "wrangler": "^4.98.0"
  }
}