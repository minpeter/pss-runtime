{
  "name": "@minpeter/pss-worker-agent",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p dev:worker dev:relay",
    "dev:worker": "wrangler dev",
    "dev:relay": "tsx scripts/telegram.ts relay",
    "ship": "run-s ship:secrets ship:worker ship:webhook",
    "ship:secrets": "wrangler secret bulk .dev.vars",
    "ship:worker": "wrangler deploy",
    "ship:webhook": "tsx scripts/telegram.ts webhook",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@chat-adapter/state-memory": "4.30.0",
    "@chat-adapter/telegram": "4.30.0",
    "ai": "^6.0.198",
    "chat": "4.30.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "@cloudflare/workers-types": "^4.20260608.1",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "wrangler": "^4.98.0"
  }
}