{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pss-worker-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-08",
  "compatibility_flags": ["nodejs_compat"],
  "dev": {
    "ip": "127.0.0.1",
    "port": 8792
  },
  "observability": {
    "logs": {
      "enabled": false,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false
    }
  }
}