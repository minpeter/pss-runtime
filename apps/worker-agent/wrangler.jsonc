{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pss-worker-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-08",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "ENVIRONMENT": "production"
  },
  "version_metadata": {
    "binding": "CF_VERSION_METADATA"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "AGENT_DO",
        "class_name": "AgentDurableObject"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["AgentDurableObject"]
    }
  ],
  "env": {
    "dev": {
      "vars": {
        "ENVIRONMENT": "development"
      },
      "version_metadata": {
        "binding": "CF_VERSION_METADATA"
      },
      "durable_objects": {
        "bindings": [
          {
            "name": "AGENT_DO",
            "class_name": "AgentDurableObject"
          }
        ]
      }
    }
  },
  "dev": {
    // Avoid clashing with bori local MGW (often on 8792).
    "ip": "127.0.0.1",
    "port": 8802
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true
    }
  }
}
