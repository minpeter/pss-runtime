{
  "name": "@minpeter/pss-coding-agent",
  "version": "0.0.13",
  "description": "Coding-agent model and TUI wiring for pss-next.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@minpeter/pss-source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./env": {
      "@minpeter/pss-source": "./src/env.ts",
      "types": "./dist/env.d.ts",
      "import": "./dist/env.js"
    },
    "./model": {
      "@minpeter/pss-source": "./src/model.ts",
      "types": "./dist/model.d.ts",
      "import": "./dist/model.js"
    },
    "./thread-config": {
      "@minpeter/pss-source": "./src/thread-config.ts",
      "types": "./dist/thread-config.d.ts",
      "import": "./dist/thread-config.js"
    },
    "./thread-inspect": {
      "@minpeter/pss-source": "./src/thread-inspect.ts",
      "types": "./dist/thread-inspect.d.ts",
      "import": "./dist/thread-inspect.js"
    },
    "./tools": {
      "@minpeter/pss-source": "./src/tools.ts",
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    },
    "./tui": {
      "@minpeter/pss-source": "./src/tui.ts",
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    }
  },
  "bin": {
    "pss": "./bin/pss.js",
    "pss-coding-agent": "./bin/pss.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minpeter/pss-runtime.git",
    "directory": "apps/coding-agent"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "start": "tsx --conditions=@minpeter/pss-source src/tui.ts",
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "ultracite check ."
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "3.0.2",
    "@earendil-works/pi-tui": "^0.80.7",
    "@minpeter/opensearch": "0.0.4",
    "@minpeter/pss-runtime": "workspace:^",
    "@t3-oss/env-core": "^0.13.11",
    "ai": "7.0.16",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsdown": "^0.22.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  }
}
